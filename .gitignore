# .gitignore for a Django project
# See: https://github.com/github/gitignore/blob/main/Python.gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,pytest_cache/
.pytest_cache/
htmlcov/

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
# Ignore media and collected static files (user uploads and collectstatic output)
media/
staticfiles/

# If you store secrets or environment variables in files
.env
.env.*
env.local
secrets.env

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# PyCharm
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor swap files
*~
*.swp
*.swo

# Logs
logs/
*.log

# Static/node
node_modules/
yarn-error.log
package-lock.json

# MyPy
.mypy_cache/

# Pyre
.pyre/

# Pytype
.pytype/

# Celery
celerybeat-schedule
celerybeat.pid

# SSH keys, certs
*.pem
*.key

# Local env for IDEs
.envrc

# Coverage reports
coverage.xml

# Python bytecode in wheel builds
*.egg-info/

